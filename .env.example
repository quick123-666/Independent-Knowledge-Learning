# ==========================================
# 知识付费平台 - 环境变量模板
# ==========================================

# 数据库连接地址（PostgreSQL）
# 格式: postgresql://用户名:密码@主机:端口/数据库名?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/knowledge_pay?schema=public"

# JWT 密钥（用于签名和验证 Token，请使用足够复杂的随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# JWT 过期时间（例如: 1d = 1天, 7d = 7天, 24h = 24小时）
JWT_EXPIRES_IN="7d"

# 服务器端口
PORT=3000

# 运行环境（development / production / test）
NODE_ENV="development"

# Stripe 支付密钥（模拟，实际项目中替换为真实密钥）
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 管理员邮箱（用于初始化管理员账号）
ADMIN_EMAIL="admin@example.com"

# CORS 允许的源（默认允许所有，生产环境应限制为具体域名）
CORS_ORIGIN="*"
