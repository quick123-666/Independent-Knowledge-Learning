// ==========================================
// 知识付费平台 - Prisma 数据库 Schema
// 开发环境使用 SQLite，生产环境切换为 PostgreSQL
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 用户模型
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  role      String   @default("USER")       // USER / ADMIN
  isBanned    Boolean  @default(false)         // 是否被封号
  bannedAt    DateTime?                       // 封号时间
  bannedReason String?                       // 封号原因
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses     Course[]     @relation("InstructorCourses")
  orders      Order[]
  enrollments Enrollment[]
  reviews     Review[]

  @@map("users")
}

// 分类模型
model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  courses Course[]

  @@map("categories")
}

// 课程模型
model Course {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String?
  coverImage    String?
  price         Float    @default(0)
  originalPrice Float?
  status        String   @default("DRAFT")   // DRAFT / PUBLISHED / ARCHIVED
  categoryId    String
  instructorId  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category   Category  @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  instructor User      @relation("InstructorCourses", fields: [instructorId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  chapters    Chapter[]
  orders      Order[]
  enrollments Enrollment[]
  reviews     Review[]

  @@map("courses")
}

// 章节模型
model Chapter {
  id        String   @id @default(uuid())
  title     String
  sortOrder Int      @default(0)
  isFree    Boolean  @default(false)
  courseId  String
  createdAt DateTime @default(now())

  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  contentBlocks ContentBlock[] @relation("ChapterBlocks")

  @@map("chapters")
}

// 内容块模型（支持视频/文章/音频/图片）
model ContentBlock {
  id        String   @id @default(uuid())
  type      String   // VIDEO / ARTICLE / AUDIO / IMAGE
  title     String
  content   String?  // 文章正文、图片描述等
  url       String?  // 视频/音频/图片的媒体地址
  duration  Int?     // 视频/音频时长（秒）
  sortOrder Int      @default(0)
  chapterId String
  createdAt DateTime @default(now())

  chapter Chapter @relation("ChapterBlocks", fields: [chapterId], references: [id], onDelete: Cascade)

  @@map("content_blocks")
}

// 订单模型
model Order {
  id            String   @id @default(uuid())
  userId        String
  courseId      String
  amount        Float
  status        String   @default("PENDING")  // PENDING / PAID / CANCELLED / REFUNDED
  paymentMethod String?
  paidAt        DateTime?
  refundedAt    DateTime?                    // 退款时间
  refundReason  String?                      // 退款原因
  createdAt     DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("orders")
}

// 报名（学习记录）模型
model Enrollment {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  progress    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chapterProgress ChapterProgress[]

  @@unique([userId, courseId])
  @@map("enrollments")
}

// 章节学习进度模型
model ChapterProgress {
  id           String   @id @default(uuid())
  enrollmentId String
  chapterId    String
  isCompleted  Boolean  @default(false)
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, chapterId])
  @@map("chapter_progress")
}

// 评价模型
model Review {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("reviews")
}
